#!/usr/bin/env python3
import os
import sys


def main():
    ros_version = os.environ.get("ROS_VERSION")
    if ros_version == "1":
        from netft_driver.ros1_node import main as node_main
    elif ros_version == "2":
        from netft_driver.ros2_node import main as node_main
    else:
        raise RuntimeError("ROS_VERSION must be 1 or 2")
    return node_main()


if __name__ == "__main__":
    try:
        result = main()
    except RuntimeError as exc:
        print(str(exc), file=sys.stderr)
        raise SystemExit(2)
    raise SystemExit(0 if result is None else result)
